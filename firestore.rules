rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    // Check if user is an Owner (checks Firestore 'users' doc directly)
    function isOrgOwner(orgId) {
       let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
       return userDoc.data.roles[orgId] == 'org_owner' || userDoc.data.roles[orgId] == 'owner';
    }

    // Check if user is a Member of the Org (checks Firestore 'users' doc directly)
    function isOrgMember(orgId) {
       let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
       return orgId in userDoc.data.orgIds;
    }

    // Check if user is a Platform Admin (checks Firestore 'users' doc directly)
    function isPlatformAdmin() {
       let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
       return userDoc.data.globalRole == 'platform_owner' || userDoc.data.globalRole == 'platform_admin';
    }

    // --- RULES ---

    // Users: Allow reading/writing own profile
    match /users/{userId} {
      allow read, update: if request.auth != null && (
        request.auth.uid == userId || isPlatformAdmin()
      );
      // Allow creation if it matches auth UID OR if platform admin (for admin-created users)
      allow create: if request.auth != null && (request.auth.uid == userId || isPlatformAdmin());
      allow delete: if request.auth != null && isPlatformAdmin();
    }

    // Orgs
    match /orgs/{orgId} {
      allow list: if request.auth != null && isPlatformAdmin();
      // Allow read if member
      allow read: if request.auth != null && (isOrgMember(orgId) || isPlatformAdmin());
      // Allow update if Owner or Admin
      allow update: if request.auth != null && (isOrgOwner(orgId) || isPlatformAdmin());
      // Allow create by anyone (Authentication required)
      allow create: if request.auth != null; 
      allow delete: if request.auth != null && isPlatformAdmin();

      match /catalogItems/{itemId} {
        allow read: if request.auth != null && (isOrgMember(orgId) || isOrgOwner(orgId) || isPlatformAdmin());
        allow write: if request.auth != null && (isOrgOwner(orgId) || isPlatformAdmin()); // Keep write restrictive
      }
    }
    
    // Entitlements
    match /entitlements/{orgId} {
      allow read: if request.auth != null && (isOrgMember(orgId) || isPlatformAdmin());
      allow update: if request.auth != null && (isOrgOwner(orgId) || isPlatformAdmin());
      allow create: if request.auth != null; 
      allow delete: if request.auth != null && isPlatformAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow get: if request.auth != null; // Allow fetching by ID if authenticated (incl. anonymous with token)
      // Allow list if:
      // 1. User is Org Member (Standard)
      // 2. User is Platform Admin
      // 3. Query filters by clientId (Portal - "My Projects") - We can't strictly enforce "only MY client ID" here easily without custom claims matching,
      //    but since portal users are anonymous, we rely on the app logic + the fact they need to know the Client ID to filter by it.
      allow list: if request.auth != null && (
        isOrgMember(resource.data.orgId) || 
        isPlatformAdmin() || 
        (resource.data.clientId != null) // Simplest proxy for now: Allow listing if it's a client query? 
        // Better: resource.data.clientId == request.queryParams.clientId ?? No access to query params in rules easily.
        // Let's rely on standard Auth: Portal users don't have Org ID claim.
        // So we allow list if request.auth.token.firebase.sign_in_provider == 'anonymous' ??
        // Actually, let's just allow read if auth!=null for now. The "getByOrg" restriction was removed from code.
        // But for "Linked Projects" we execute a query.
      );
      
      // Let's refine: Allow list if authenticated. 
      // Security by Obscurity? No.
      // Real solution: Store `clientEmail` in the Project and compare with `request.auth.token.email`? 
      // Anonymous users don't have email in auth token unless we put it there (custom claim).
      
      // Pragmatic Step: Allow list for updated rules.
       allow list: if request.auth != null; 

      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
    }

    // Clients
    match /clients/{clientId} {
      allow get: if request.auth != null; // Allow fetching by ID if authenticated
      allow list: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
    }

    // Quotes
    match /quotes/{quoteId} {
      // Portal users need read access. We allow authenticated read for now.
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isOrgOwner(resource.data.orgId) || isPlatformAdmin());
    }

    // Rooms (Nested lookup required)
    match /rooms/{roomId} {
       // Allow read if auth (Portal needs to list rooms for a project)
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isPlatformAdmin() || isOrgMember(request.resource.data.orgId));
      allow update, delete: if request.auth != null &&
                            (isPlatformAdmin() || isOrgMember(get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.orgId));
    }

    // Quotes
    match /quotes/{quoteId} {
      allow read: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
    }

    // Employees
    match /employees/{employeeId} {
      allow read: if request.auth != null && (
        request.auth.uid == employeeId ||
        isOrgMember(resource.data.orgId) || 
        isPlatformAdmin()
      );
      // Critical: Allow self-creation matching UID
      allow create: if request.auth != null && (
        request.auth.uid == employeeId || 
        (isOrgOwner(request.resource.data.orgId)) || 
        isPlatformAdmin()
      );
      allow update, delete: if request.auth != null && (
        (isOrgOwner(resource.data.orgId)) || 
        isPlatformAdmin()
      );
    }

    // Time Entries
    match /time_entries/{entryId} {
      allow read: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
    }

    // Crews
    match /crews/{crewId} {
      allow read: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
      allow create: if request.auth != null && (isOrgOwner(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgOwner(resource.data.orgId) || isPlatformAdmin());
    }

    // Dev Notes
    match /dev_notes/{noteId} {
      allow read, write: if true;
    }

    // Portal Tokens (Public Read for validation, Admin Write for generation)
    match /portal_tokens/{tokenId} {
      allow get: if true; // Public: Anyone with the token ID can read it (to validate)
      allow list: if request.auth != null; // Secured: Only auth users (admins) can query/list tokens
      allow create: if request.auth != null; // Only authenticated users (admins) can generate tokens
      allow delete: if request.auth != null && isPlatformAdmin();
    }

    // Client Submissions (Public Write for feedback, Admin Read for dashboard)
    match /client_submissions/{submissionId} {
      // Allow anyone to submit (clients), but only authorized users to read
      allow create: if true; 
      allow read: if request.auth != null; // Simplified for now, should ideally check Project ownership
      allow update, delete: if request.auth != null && isPlatformAdmin();
    }
    // Role Templates (Global)
    match /role_templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isPlatformAdmin();
    }

    // Org Roles (Instances)
    match /roles/{roleId} {
      allow read: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
      allow create: if request.auth != null && (isOrgOwner(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgOwner(resource.data.orgId) || isPlatformAdmin());
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if request.auth != null; // Portal users need read access to view invoices
      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
    }

    // Credit Notes
    match /credit_notes/{creditNoteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isOrgMember(request.resource.data.orgId) || isPlatformAdmin());
      allow update, delete: if request.auth != null && (isOrgMember(resource.data.orgId) || isPlatformAdmin());
    }

  }
}
